{
  "name": "cekwajar-agents",
  "version": "0.1.0",
  "description": "Python agents for data scraping and processing for cekwajar.id",
  "scripts": {
    "monthly-pipeline": "python -m agents.orchestrators.monthly_data_refresh",
    "scrape-property": "python -m agents.scrapers.property_scraper",
    "scrape-salary": "python -m agents.scrapers.salary_scraper",
    "scrape-numbeo": "python -m agents.scrapers.numbeo_scraper",
    "validate-data": "python -m agents.processors.data_validator",
    "aggregate": "python -m agents.processors.benchmark_aggregator"
  },
  "dependencies": [
    "swarms>=1.0.0",
    "playwright>=1.40.0",
    "supabase>=2.0.0",
    "pandas>=2.0.0",
    "httpx>=0.27.0",
    "python-dotenv>=1.0.0",
    "schedule>=1.2.0"
  ]
}